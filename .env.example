# ============================================================
# Kappa Harness OS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── LLM Provider ────────────────────────────────────────────
# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for worker agents and orchestrator
LLM_MODEL=claude-sonnet-4-20250514

# ── Budget Gate ─────────────────────────────────────────────
# Maximum total tokens per session (circuit breaker trips at limit)
BUDGET_MAX_TOKENS=100000

# Maximum USD spend per session
BUDGET_MAX_COST_USD=5.00

# ── Docker Sandbox ──────────────────────────────────────────
# Execution timeout per container (seconds)
SANDBOX_TIMEOUT_SECONDS=30

# Memory limit per container (MB)
SANDBOX_MEMORY_LIMIT_MB=256

# ── Self-Healing ────────────────────────────────────────────
# Maximum code-fix-rerun cycles before giving up
MAX_SELF_HEAL_RETRIES=3

# ── Orchestrator ────────────────────────────────────────────
# Exponential backoff for transient failures
BACKOFF_BASE_DELAY=1.0
BACKOFF_MAX_DELAY=60.0
BACKOFF_MAX_RETRIES=5

# Session lane lock timeout (seconds)
SESSION_LANE_TIMEOUT=30.0

# ── RAG Pipeline ────────────────────────────────────────────
# Character-level chunking parameters
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# Number of top results returned per query
RAG_TOP_K=5

# Minimum similarity score filter (0.0 = no filter)
RAG_MIN_SCORE=0.0

# ── MCP Bridge ──────────────────────────────────────────────
# Timeout for MCP server requests (seconds)
MCP_REQUEST_TIMEOUT=30.0

# Max retries for failed MCP calls
MCP_MAX_RETRIES=2

# ── Telemetry ───────────────────────────────────────────────
# JSONL trajectory log path (relative to project root)
TELEMETRY_LOG_PATH=.kappa_telemetry/trajectories.jsonl

# ── VFS Memory ──────────────────────────────────────────────
# Agent workspace root directory
MEMORY_WORKSPACE_ROOT=.kappa_workspace
